{
  "name": "the-moon-web",
  "type": "module",
  "version": "0.3.4",
  "scripts": {
    "dev": "astro dev",
    "dev:pb": "./tools/pocketbase/pocketbase serve --dir=./tools/pocketbase/pb_data --migrationsDir=./tools/pocketbase/pb_migrations",
    "setup:pb": "sh scripts/setup-pocketbase.sh",
    "start": "concurrently --names \"PB,MAIL,WEB\" --prefix-colors \"red,yellow,cyan\" \"pnpm dev:pb\" \"mailpit\" \"pnpm dev\" --on-start \"echo '' && echo '  📬  Mailpit    → http://localhost:8025' && echo '  🗄️   PocketBase → http://localhost:8090/_/' && echo '  🌐  Web        → http://localhost:4321' && echo ''\"",
    "build": "astro build",
    "preview": "astro preview"
  },
  "dependencies": {
    "@astrojs/node": "^10.0.4",
    "@astrojs/vue": "^6.0.1",
    "@fontsource/josefin-sans": "^5.2.8",
    "@fontsource/space-mono": "^5.2.9",
    "@tailwindcss/vite": "^4.2.2",
    "astro": "^6.1.3",
    "fflate": "^0.8.2",
    "lenis": "^1.3.23",
    "lucide-astro": "^0.556.0",
    "marked": "^18.0.2",
    "nodemailer": "^8.0.5",
    "pinia": "^3.0.4",
    "tailwindcss": "^4.2.2",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^8.0.0",
    "concurrently": "^9.2.1"
  }
}
