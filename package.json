    "lucide-astro": "^0.556.0",
    "nodemailer": "^8.0.5",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^8.0.0",
    "concurrently": "^9.2.1"
