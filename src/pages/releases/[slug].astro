---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import AudioPlayer from '../../components/AudioPlayer.astro';
import PhaseCircle from '../../components/PhaseCircle.astro';
import releasesData from '../../../the-moon-os/data/releases.json';
import { getFeedbackForRelease } from '../../lib/pocketbase';

const { slug } = Astro.params;
const release = releasesData.releases.find(
  (r) => r.catalog.toLowerCase() === slug
);

if (!release) return Astro.redirect('/404');

const feedback = await getFeedbackForRelease(slug!);

const { catalog, artist, title, format, year, genre, artwork, cover, tracks, platforms, release_date } = release;

const art1500webp = artwork?.['1500']?.webp;
const art1500jpg  = artwork?.['1500']?.jpg;

const playerTracks = tracks.map((t) => ({
  number: t.number,
  title:  t.title,
  url:    t.url,
}));

// Only show platform links if release_date is in the past
const now = new Date();
const releaseDate = release_date ? new Date(release_date) : null;
const isReleased = releaseDate ? releaseDate <= now : true;
const visiblePlatforms = isReleased ? platforms?.filter((p) => p.url) : [];

// Format release date for display
const formattedReleaseDate = releaseDate
  ? releaseDate.toLocaleDateString('en-GB', { day: '2-digit', month: 'long', year: 'numeric' })
  : null;

const seoTitle       = `${artist} — ${title} | THE MOON RECORDS`;
const seoDescription = `${catalog}${genre ? ` · ${genre}` : ''}${year ? ` · ${year}` : ''} · ${tracks.length} track${tracks.length !== 1 ? 's' : ''}. Beatless music on The Moon Records.`;
const seoImage       = artwork?.['1500']?.jpg || cover;
const seoUrl         = new URL(`releases/${slug}`, Astro.site).href;
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  image={seoImage}
  canonicalUrl={seoUrl}
  type="music.album"
>
  <div class="min-h-screen pb-24">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 pt-8">

      <!-- Back nav -->
      <nav class="mb-12 pt-6">
        <a
          href="/"
          class="font-mono text-[0.6rem] tracking-[0.25em] uppercase text-fg-muted no-underline transition-colors duration-200 hover:text-fg-dim"
        >← The Moon Records</a>
      </nav>

      <!-- Hero grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-12 lg:gap-16 items-start">

        <!-- Artwork -->
        <div class="sm:sticky sm:top-8">
          {art1500jpg ? (
            <picture>
              {art1500webp && <source srcset={art1500webp} type="image/webp" />}
              <img
                class="release-artwork w-full aspect-square object-cover block [filter:grayscale(0.2)_brightness(0.9)] hover:[filter:grayscale(0)_brightness(1)] transition-[filter] duration-300"
                src={art1500jpg}
                alt={`${artist} — ${title}`}
                width="600"
                height="600"
              />
            </picture>
          ) : (
            <div class="w-full aspect-square bg-surface border border-border flex items-center justify-center">
              <PhaseCircle phase={0.74} size={120} label="No cover art" />
            </div>
          )}
        </div>

        <!-- Info column -->
        <div class="flex flex-col gap-5">

          <!-- Badges -->
          <div class="flex gap-1.5 flex-wrap">
            <span class="badge">{catalog}</span>
            {format && <span class="badge badge--muted">{format}</span>}
            {genre  && <span class="badge badge--muted">{genre}</span>}
            {year   && <span class="badge badge--muted">{year}</span>}
          </div>

          <h1
            id="release-title"
            class="font-label font-bold uppercase text-fg leading-[1.05]"
            style="font-size: clamp(1.5rem, 4vw, 2.5rem); letter-spacing: 0.06em;"
          >{title}</h1>

          <p class="font-label font-normal text-[0.75rem] tracking-[0.22em] uppercase text-accent">{artist}</p>

          <!-- Track count + Platforms -->
          <div class="flex items-center gap-6 pb-4 border-b border-border flex-wrap">
            <span class="font-mono text-[0.55rem] tracking-[0.2em] uppercase text-fg-muted">
              {tracks.length} track{tracks.length !== 1 ? 's' : ''}
            </span>
            {visiblePlatforms?.map((p) => (
              <a
                href={p.url}
                target="_blank"
                rel="noopener noreferrer"
                class="font-mono text-[0.55rem] tracking-[0.2em] uppercase text-accent no-underline transition-opacity duration-200 hover:opacity-70"
              >{p.name} ↗</a>
            ))}
          </div>

          <!-- Release date + Newsletter CTA -->
          {formattedReleaseDate && (
            <div class="flex items-center gap-6 flex-wrap">
              <span class="font-mono text-[0.55rem] tracking-[0.2em] uppercase text-fg-muted">
                {isReleased ? 'Released' : 'Releasing'} {formattedReleaseDate}
              </span>
              {!isReleased && (
                <a
                  href="/newsletter"
                  class="font-mono text-[0.55rem] tracking-[0.2em] uppercase text-accent no-underline transition-opacity duration-200 hover:opacity-70"
                >Get notified ↗</a>
              )}
            </div>
          )}

          <!-- Phase indicator row -->
          <div class="flex items-center gap-4">
            <PhaseCircle phase={0.74} size={48} label="Phase indicator" />
            <span class="font-mono text-[0.55rem] tracking-[0.22em] uppercase text-fg-muted">
              {catalog}
            </span>
          </div>

          <!-- Audio player (only if released) -->
          {isReleased ? (
            <AudioPlayer tracks={playerTracks} />
          ) : (
            <div class="border border-border p-5 flex flex-col gap-2">
              <span class="font-mono text-[0.6rem] tracking-[0.25em] uppercase text-accent">// TRANSMISSION_PENDING</span>
              <p class="font-mono text-[0.55rem] tracking-[0.18em] uppercase text-fg-muted">
                Available {formattedReleaseDate}
              </p>
            </div>
          )}

          <!-- Feedback -->
          {feedback.length > 0 && (
            <div class="flex flex-col gap-4 pt-2">
              <span class="font-mono text-[0.6rem] tracking-[0.25em] uppercase text-accent">// Transmissions</span>
              {feedback.map((f) => (
                <div class="border border-border p-4 flex flex-col gap-2">
                  <p class="font-label text-[0.75rem] tracking-[0.08em] text-fg-dim leading-relaxed">"{f.comment}"</p>
                  <div class="flex items-baseline gap-3 flex-wrap">
                    <span class="font-mono text-[0.55rem] tracking-[0.2em] uppercase text-fg-muted">{f.name}</span>
                    {f.url && (
                      <a
                        href={f.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="font-mono text-[0.5rem] tracking-[0.15em] uppercase text-accent no-underline opacity-70 hover:opacity-100 transition-opacity"
                      >{new URL(f.url).hostname} ↗</a>
                    )}
                  </div>
                </div>
              ))}
            </div>
          )}

        </div>
      </div>

    </div>
  </div>
<script>
  // On mobile, scroll the release title into view so it's clear the page changed
  if (window.matchMedia('(max-width: 639px)').matches) {
    const title = document.getElementById('release-title');
    if (title) {
      const headerHeight = 64; // h-16
      const y = title.getBoundingClientRect().top + window.scrollY - headerHeight - 80;
      window.scrollTo({ top: y, behavior: 'smooth' });
    }
  }
</script>
</BaseLayout>
