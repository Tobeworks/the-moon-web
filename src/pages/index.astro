---
import BaseLayout from "../layouts/BaseLayout.astro";
import PhaseCircle from "../components/PhaseCircle.astro";
import ReleaseList from "../components/ReleaseList.astro";
import NewsletterForm from "../components/NewsletterForm.astro";
import releasesData from "../../the-moon-os/data/releases.json";

const latestCatalog =
  releasesData.releases
    .map((r) => r.catalog)
    .sort()
    .at(-1) ?? "TMR-001";
---

<BaseLayout
  title="THE MOON RECORDS"
  description="Independent beatless music label. Ambient, Drone, Soundscape."
  canonicalUrl={new URL("", Astro.site).href}>
  <!-- ── Hero ── -->
  <section
    class="min-h-screen grid grid-cols-1 md:grid-cols-2 grid-rows-[1fr_auto] px-6 lg:px-10 pb-12 relative overflow-hidden">
    <!-- Atmospheric glow — barely visible radial hint -->
    <div
      class="absolute inset-0 pointer-events-none"
      style="background: radial-gradient(ellipse 55% 50% at 72% 48%, rgba(196,185,138,0.025) 0%, transparent 65%);"
      aria-hidden="true">
    </div>

    <!-- Left: text content -->
    <div class="flex flex-col justify-center pt-16 z-1 order-2 md:order-1">
      <span
        class="flex items-center gap-3 font-mono text-[0.6rem] tracking-[0.35em] uppercase text-accent mb-8">
        <span class="block w-8 h-px bg-accent opacity-50 shrink-0"></span>
        01 — Lunar Program
      </span>

      <h1
        class="hero-title font-label font-bold uppercase text-fg mb-8"
        style="font-size: clamp(3.5rem, 8.5vw, 7.5rem); letter-spacing: 0.03em; line-height: 0.9;">
        The Moon<br />Records
      </h1>

      <div class="w-full h-px bg-border mb-6"></div>

      <p
        class="font-label font-light text-[0.75rem] tracking-[0.3em] uppercase text-fg-dim mb-12">
        AN ARCHITECTURAL EXPLORATION OF SOUNDSCAPES
      </p>

      <div class="flex gap-3 flex-wrap">
        <a href="#releases" class="btn btn--primary">Current Phase</a>
        <a href="#field" class="btn btn--muted">Field Notes</a>
      </div>
    </div>

    <!-- Right: large precision circle -->
    <div
      class="flex items-center justify-center pt-16 pb-8 md:pb-0 order-1 md:order-2">
      <PhaseCircle
        phase={0.74}
        size={420}
        phaseCode="WXG / 74%"
        label="Waxing gibbous — 74% illuminated"
        class="w-full h-auto max-w-[420px]"
      />
    </div>

    <!-- Bottom meta strip -->
    <div
      class="col-span-full flex gap-8 lg:gap-12 pt-10 border-t border-border flex-wrap order-3">
      {
        [
          ["Label", "The Moon Records"],
          ["Field", "Ambient"],
          ["Est.", "2024"],
        ].map(([label, value]) => (
          <div class="flex gap-4 font-mono text-[0.575rem] tracking-[0.25em] uppercase">
            <span class="text-fg-muted">{label}</span>
            <span class="text-fg-dim">{value}</span>
          </div>
        ))
      }
    </div>
  </section>

  <!-- ── 01 Current Phase — Releases ── -->
  <section class="py-24" id="releases">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="tmr-section-header">
        <span class="tmr-section-num">01</span>
        <span class="tmr-section-title">Current Phase</span>
        <span class="tmr-section-sub">TMR / Latest</span>
      </div>
      <ReleaseList limit={12} />
      {
        releasesData.releases.length > 12 && (
          <div class="mt-10 flex justify-center">
            <a
              href="/releases"
              class="btn btn--muted font-mono text-[0.6rem] tracking-[0.25em] uppercase">
              All Releases ({releasesData.releases.length}) →
            </a>
          </div>
        )
      }
    </div>
  </section>

  <!-- ── 02 Field — Label Statement ── -->
  <section class="py-24 bg-surface-low" id="field">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="tmr-section-header">
        <span class="tmr-section-num">02</span>
        <span class="tmr-section-title">Field</span>
        <span class="tmr-section-sub">About</span>
      </div>

      <div
        class="grid grid-cols-1 lg:grid-cols-[3fr_2fr] gap-12 lg:gap-20 items-start">
        <!-- Text -->
        <div
          class="flex flex-col gap-5 font-label font-light text-[0.975rem] leading-loose text-fg-dim">
          <p>
            The Moon Records is a mostly beatless label. Ambient and Drone
            across the full spectrum. Lo-fi warmth, field recording and
            synthesis, sustained tones, deep drone, Space Soundscape udn more.
          </p>
          <p>
            The music here does not push. It accumulates. It holds still long
            enough to be heard.
          </p>
          <p>
            The label name originates with Logic Moon, the founding artist whose
            sound defined the initial position. The scope has since opened: any
            artist operating within the spectrum belongs here, provided the work
            has internal logic and was made with intention.
          </p>
        </div>

        <!-- Data table -->
        <div class="border-t border-border">
          {
            [
              ["Founded", "2024"],
              ["Format", "Digital / Limited Physical"],
              ["Catalog", `TMR001 → ${latestCatalog}`],
              ["Spectrum", "Ambient — Drone — Soundscape"],
              ["Beatless", "Always"],
              ["Platform", "Bandcamp / DSP"],
            ].map(([label, value]) => (
              <div class="flex gap-4 py-3 border-b border-border font-mono text-[0.6rem] tracking-[0.14em] uppercase">
                <span class="text-fg-muted min-w-22">{label}</span>
                <span class="text-fg-dim">{value}</span>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- ── 03 Subscribe ── -->
  <section class="py-24" id="subscribe">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="tmr-section-header">
        <span class="tmr-section-num">03</span>
        <span class="tmr-section-title">Subscribe</span>
        <span class="tmr-section-sub">New Phase / Notify</span>
      </div>

      <div class="max-w-128 mx-auto text-center pt-4">
        <h2
          class="font-label font-light text-[1.5rem] tracking-[0.12em] uppercase text-fg mb-2">
          Stay in the field.
        </h2>
        <p
          class="font-mono text-[0.6rem] tracking-[0.25em] uppercase text-fg-muted mb-10">
          Releases and transmissions — nothing else.
        </p>
        <div class="text-left">
          <NewsletterForm />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
