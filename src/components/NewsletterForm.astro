---
const { error } = Astro.props as { error?: string };
---

<div id="nl-form-wrap">
  {error === 'expired' && (
    <p class="font-mono text-[0.75rem] tracking-[0.05em] leading-relaxed px-4 py-3 mb-6 text-accent border border-border bg-[rgba(196,185,138,0.04)]">
      Link expired — please resubmit to receive a new confirmation link.
    </p>
  )}
  {error === 'invalid' && (
    <p class="font-mono text-[0.75rem] tracking-[0.05em] leading-relaxed px-4 py-3 mb-6 text-accent border border-border bg-[rgba(196,185,138,0.04)]">
      Invalid link — please resubmit your email address.
    </p>
  )}

  <form id="nl-form" novalidate>
    <div class="flex flex-col gap-5 mb-6">
      <div class="flex flex-col gap-1.5">
        <label for="nl-name" class="font-label font-light text-[0.75rem] tracking-[0.12em] text-fg-dim">
          Name <span class="text-fg-muted">(optional)</span>
        </label>
        <input
          class="tmr-input w-full"
          type="text"
          id="nl-name"
          name="name"
          placeholder="e.g. Logic Moon"
          maxlength="100"
          autocomplete="name"
        />
      </div>
      <div class="flex flex-col gap-1.5">
        <label for="nl-email" class="font-label font-light text-[0.75rem] tracking-[0.12em] text-fg-dim">
          Email address <span class="text-accent text-[0.65rem]">*</span>
        </label>
        <input
          class="tmr-input w-full"
          type="email"
          id="nl-email"
          name="email"
          placeholder="your@email.com"
          required
          autocomplete="email"
        />
      </div>
    </div>

    <div class="flex items-start gap-6 flex-wrap">
      <button type="submit" class="btn btn--primary shrink-0" id="nl-submit">
        <span id="nl-btn-label">Subscribe</span>
      </button>
      <p class="font-label font-light text-[0.75rem] tracking-[0.04em] text-fg-muted leading-relaxed m-0">
        Double opt-in — you'll receive a confirmation link via email.
        No spam. Unsubscribe any time.
      </p>
    </div>

    <p class="font-mono text-[0.75rem] tracking-[0.05em] text-accent mt-4 hidden" id="nl-error"></p>
  </form>

  <div id="nl-success" class="flex-col gap-3 hidden">
    <span class="font-mono text-[0.65rem] tracking-[0.3em] uppercase text-accent">// Transmission queued</span>
    <p class="font-label font-light text-[0.9rem] tracking-[0.04em] text-fg-dim leading-relaxed m-0">
      Check your inbox and click the confirmation link to complete sign-up.
    </p>
  </div>
</div>

<script>
  const form     = document.getElementById('nl-form')      as HTMLFormElement;
  const success  = document.getElementById('nl-success')   as HTMLElement;
  const errorEl  = document.getElementById('nl-error')     as HTMLElement;
  const submit   = document.getElementById('nl-submit')    as HTMLButtonElement;
  const btnLabel = document.getElementById('nl-btn-label') as HTMLElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorEl.classList.add('hidden');

    const email = (form.querySelector('#nl-email') as HTMLInputElement).value.trim();
    const name  = (form.querySelector('#nl-name')  as HTMLInputElement).value.trim();

    if (!email) {
      errorEl.textContent = 'Email address required.';
      errorEl.classList.remove('hidden');
      return;
    }

    submit.disabled = true;
    btnLabel.textContent = 'Sending…';

    try {
      const res = await fetch('/api/newsletter/subscribe', {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify({ email, name }),
      });

      if (!res.ok) throw new Error('Server error');

      form.classList.add('hidden');
      success.classList.remove('hidden');
      success.classList.add('flex');
    } catch {
      errorEl.textContent = 'Transmission failed — please try again.';
      errorEl.classList.remove('hidden');
      submit.disabled = false;
      btnLabel.textContent = 'Subscribe';
    }
  });
</script>
