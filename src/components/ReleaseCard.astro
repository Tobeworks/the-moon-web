---
interface Track {
  number: number;
  title: string;
  bpm: string;
  key: string;
  runtime: string;
  url: string;
  url_320: string;
}

interface Release {
  catalog: string;
  artist: string;
  title: string;
  format: string;
  year: string;
  genre: string;
  cover: string;
  artwork: Record<string, { jpg: string; webp: string }>;
  bandcamp: string;
  tracks: Track[];
}

interface Props {
  release: Release;
}

const { release } = Astro.props;
const { catalog, artist, title, cover, artwork, tracks } = release;

const coverWebp = artwork?.['600']?.webp || cover;
const coverJpg  = artwork?.['600']?.jpg  || cover;
const slug = catalog.toLowerCase();

const totalRuntime = tracks.reduce((sum, t) => {
  if (!t.runtime) return sum;
  const parts = t.runtime.split(':').map(Number);
  return parts.length === 2 ? sum + parts[0] * 60 + parts[1] : sum;
}, 0);

const runtime = totalRuntime > 0
  ? `${Math.floor(totalRuntime / 60)}:${String(totalRuntime % 60).padStart(2, '0')}`
  : '';
---

<a href={`/releases/${slug}`} class="release-card flex flex-col bg-surface-low no-underline text-inherit transition-opacity duration-200 hover:opacity-80">

  <!-- Cover art -->
  <div class="aspect-square overflow-hidden bg-surface-high">
    {coverJpg ? (
      <picture>
        <source srcset={coverWebp} type="image/webp" />
        <img
          class="cover-img w-full h-full object-cover block transition-[filter] duration-300"
          src={coverJpg}
          alt={`${artist} — ${title}`}
          loading="lazy"
          width="600"
          height="600"
        />
      </picture>
    ) : (
      <div class="w-full h-full bg-surface-high flex items-center justify-center">
        <svg viewBox="0 0 80 80" fill="none" aria-hidden="true" class="w-2/5 h-2/5 opacity-20">
          <clipPath id="rpc"><circle cx="40" cy="40" r="28"/></clipPath>
          <circle cx="40" cy="40" r="28" stroke="#C4B98A" stroke-width="0.8" opacity="0.5"/>
          <g clip-path="url(#rpc)">
            <path d="M 40 12 A 28 28 0 1 1 40 68 A 11 28 0 1 0 40 12 Z" fill="#C4B98A" opacity="0.5"/>
          </g>
        </svg>
      </div>
    )}
  </div>

  <!-- Info -->
  <div class="p-4 border-t border-border flex flex-col gap-[0.35rem]">
    <div class="font-label font-normal text-[0.65rem] tracking-[0.2em] uppercase text-accent">{artist}</div>
    <h3 class="font-label font-semibold text-[0.95rem] uppercase tracking-[0.06em] text-fg leading-[1.2] mt-0.5">{title}</h3>
    <div class="flex justify-between font-mono text-[0.55rem] tracking-[0.18em] uppercase text-fg-muted mt-2.5">
      <span>{catalog}</span>
      <span>{tracks.length} track{tracks.length !== 1 ? 's' : ''}{runtime ? ` · ${runtime}` : ''}</span>
    </div>
  </div>

</a>

<style>
  /* Cover filter — grayscale at rest, full color on hover */
  .cover-img {
    filter: grayscale(0.4) brightness(0.85);
  }
  .release-card:hover .cover-img {
    filter: grayscale(0) brightness(1);
  }
</style>
